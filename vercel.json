{
  "version": 2,
  "installCommand": "cd app/frontend && pnpm i",
  "buildCommand": "cd app/frontend && pnpm run build",
  "outputDirectory": "app/frontend/dist",
  "rewrites": [
    {
      "source": "/((?!assets/|favicon.svg|robots.txt|sitemap.xml|llms.txt).*)",
      "destination": "/index.html"
    }
  ]
}
