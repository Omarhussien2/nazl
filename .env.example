# ============================================================================
# نزل (Nuzul) — Environment Variables
# Copy this file to `.env` and fill in the real values.
# Never commit `.env` to git.
# ============================================================================

# ---------- Application ----------
APP_NAME="Nuzul Backend"
DEBUG=false
VERSION=1.0.0

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000

# ---------- Database ----------
# Local dev: sqlite default. Production: Neon/Supabase/RDS Postgres URL.
# Example: postgresql+asyncpg://user:pass@ep-xxx.eu-central-1.aws.neon.tech/nazl
DATABASE_URL=sqlite+aiosqlite:///./nazl.db

# ---------- Auth ----------
# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-minimum-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Admin bootstrap (first-run only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ---------- Google OAuth (Phase 1) ----------
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ---------- Transcription (Groq Whisper — Phase 1) ----------
# https://console.groq.com/keys — free tier sufficient for MVP
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ---------- Media Download (yt-dlp + gallery-dl) ----------
# Optional: cookies file for age-gated / region-locked public content.
# Leave empty to use anonymous extraction only.
YTDLP_COOKIES_FILE=
GALLERY_DL_ENABLED=true

# Daily usage limits (free tier)
FREE_DAILY_TRANSCRIPTIONS=10
FREE_MAX_VIDEO_MINUTES=60
FREE_ANONYMOUS_TRIALS=1

# ---------- Storage ----------
# Local uploads dir (dev). Production: swap for S3/R2/GCS.
UPLOADS_DIR=./uploads

# ---------- CORS ----------
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Deployment ----------
# Set to "true" when running under AWS Lambda (via Mangum).
IS_LAMBDA=false
