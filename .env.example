# ============================================================================
# نزل (Nuzul) — Environment Variables
# Copy this file to `.env` and fill in the real values.
# Never commit `.env` to git.
# ============================================================================

# ---------- Application ----------
APP_NAME="Nuzul Backend"
DEBUG=false
VERSION=1.0.0

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000

# ---------- Database ----------
# Local dev: sqlite default. Production: Neon/Supabase/RDS Postgres URL.
# Example: postgresql+asyncpg://user:pass@ep-xxx.eu-central-1.aws.neon.tech/nazl
DATABASE_URL=sqlite+aiosqlite:///./nazl.db

# ---------- Auth ----------
# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-minimum-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# JWT used for app session tokens (separate from OIDC ID tokens).
JWT_SECRET_KEY=change-me-in-production-minimum-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# Admin bootstrap (first-run only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ---------- OIDC (Google by default) ----------
# OIDC_ISSUER_URL is the canonical issuer. The app fetches
# `<issuer>/.well-known/openid-configuration` to discover the
# authorization / token / jwks endpoints — no need to hard-code them.
# Override OIDC_DISCOVERY_URL only for non-standard providers.
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile
# Google-specific (optional): request a refresh token + force re-consent.
OIDC_ACCESS_TYPE=offline
OIDC_PROMPT=consent

# Frontend / backend canonical URLs (used to build redirect URIs).
FRONTEND_URL=http://localhost:5173
PYTHON_BACKEND_URL=http://localhost:8000

# ---------- Transcription (Groq Whisper — Phase 1) ----------
# https://console.groq.com/keys — free tier sufficient for MVP
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ---------- Media Download (yt-dlp + gallery-dl) ----------
# Optional: proxy URL for yt-dlp, useful for YouTube/other platforms that block
# datacenter IPs. Supports HTTP(S) and SOCKS URLs accepted by yt-dlp.
YTDLP_PROXY_URL=
# Optional: cookies for YouTube / age-gated / region-locked public content.
# YouTube blocks datacenter IPs (Cloud Run, AWS, etc.) without cookies.
# Two ways to ship them — pick one:
#   1) YTDLP_COOKIES_TXT: paste the full Netscape-format cookies.txt content
#      inline. Friendliest for `gcloud run services update --update-env-vars`.
#   2) YTDLP_COOKIES_FILE / YTDLP_COOKIES_PATH: path to a mounted file. Use
#      this with Cloud Run Secret Manager mounts.
# Export cookies.txt from a logged-in browser via the
# "Get cookies.txt LOCALLY" Chrome extension.
YTDLP_COOKIES_TXT=
YTDLP_COOKIES_FILE=
GALLERY_DL_ENABLED=true

# Daily usage limits (free tier) — enforced by services/usage.py
DAILY_TRANSCRIBE_QUOTA=10
MAX_TRANSCRIBE_SECONDS=3600
ANONYMOUS_TRANSCRIBE_QUOTA=1

# ---------- Storage ----------
# Local uploads dir (dev). Production: swap for S3/R2/GCS.
UPLOADS_DIR=./uploads

# ---------- CORS ----------
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Deployment ----------
# Set to "true" when running under AWS Lambda (via Mangum).
IS_LAMBDA=false
